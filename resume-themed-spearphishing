//File name contains 'resume' but has an interesting extension
CrowdStrike
| where TimeGenerated > ago(30d)
//| where event_simpleName == "IsoExtensionFileWritten" or event_simpleName == "DirectoryCreate" or event_simpleName == 'FileOpenInfo' or event_simpleName == 'FileCreateInfo'
|where (FileName contains "resume" and (FileName endswith ".iso" or FileName endswith ".zip" or FileName endswith ".lnk")) //Uncomment this for precision and FP reduction, but more compute // FileName matches regex ".*resume.*\\.iso"
//| where ContextBaseFileName == "msedge.exe"  or ContextBaseFileName == "chrome.exe" or ContextBaseFileName == "firefox.exe" //Uncomment for files from a web browser
| where TargetFileName !contains "\\AppData\\Roaming\\Microsoft\\Windows\\Recent\\" and TargetFileName !contains "\\AppData\\Roaming\\Microsoft\\Office\\Recent\\"  and
TargetFileName !contains "\\AppData\\Roaming\\Microsoft\\Word\\" and TargetFileName !contains "\\AppData\\Roaming\\Microsoft\\PowerPoint" and TargetFileName !contains "\\AppData\\Roaming\\Microsoft\\Excel"  //Omit recently opened files as Windows auto creates .lnk files
| summarize  count(event_simpleName),count(FileName), make_set(ComputerName), make_set(ContextImageFileName,10), make_set(CommandLine,5), make_set(TargetFileName,10), make_set(TimeGenerated, 5), make_set(record, 10) by event_simpleName,FileName
| sort by count_event_simpleName asc

//Script Executions from removable drive(s) e.g. iso
CrowdStrike
| where TimeGenerated > ago(90d)
| where event_simpleName == "ProcessRollup2"and CommandLine matches regex @"^[D-Z]:\\" and (isempty(ParentBaseFileName) or ParentBaseFileName =~ "powershell.exe"  or ParentBaseFileName =~ "cmd.exe"  or ParentBaseFileName =~ "setup.exe"  or ParentBaseFileName =~ "RemoteExecService.exe" )
| where CommandLine !has "my" and  ComputerName != "mysccm" and  ComputerName  !contains "myweb" //Add your filters to tune out legitimate IT activity
| summarize  count(FileName), make_set(CommandLine,7), make_set(record,5) by ParentBaseFileName, FileName, ComputerName
