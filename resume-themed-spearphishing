//Hunt for files titled 'resume' but are not expected file formats.
//Note: Expect FPs for sys admin files containing 'resume', consider tuning out by role name in favor or negate HR and IT
database('Network').table('proxy')
| where TimeGenerated > ago(180d)
| where action == "Allowed"
| where filename contains "resume" and (filename endswith ".iso" or filename endswith ".zip")
| where fileclass != 'Images' and fileclass != 'Audio' and fileclass != 'Video'
| where  filename !endswith ".doc" and filename!endswith ".docx" and filename !endswith ".pdf"   and filename !endswith ".png"   and filename !endswith ".jpg" and filename !endswith ".ico" and filename !endswith ".webp" and filename !endswith ".avif" and filename !endswith ".ttf"   and filename !endswith ".svc"   and filename !endswith ".txt" and filename !endswith ".svg" and filename !endswith ".json" //
| where hostname != "my.sharepoint.com" and  hostname != "a.sharepoint.com"
| summarize count(filename), make_set(hostname), make_set(url),make_set(urlcategory), make_set(df_hostname), make_set(fileclass), make_set(referer), make_set(record.department), make_set(useragent), make_set(record, 5) by filename
| sort by count_filename asc nulls first
 
