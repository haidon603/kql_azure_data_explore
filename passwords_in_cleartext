database('Endpoint').EDR
| where TimeGenerated > ago(1d)
| where  (CommandLine matches regex @"(?i)(password|credentials|creds|login|secrets)[^\\]*\.(txt|xls|xlsx|doc|docx)" and CommandLine has "C:\\Users")
| extend ExtractedFileName = extract(@"([^\\]+)$", 1, CommandLine)
| project
    event_simpleName,
    OU,
    FileName,
    ParentBaseFileName,
    UserName,
    ExtractedFileName,
    CommandLine
