kind":"query","queryId":"40b826ae-9a8c-48f8-b82c-310552935921"},"visualOptions":{"table__enableRenderLinks":true,"colorRulesDisabled":false,"crossFilterDisabled":false,"drillthroughDisabled":false,"crossFilter":[],"drillthrough":[],"table__renderLinks":[],"colorRules":[{"id":"10db6d3d-5c8f-4ca2-925a-0188177f746e","ruleType":"colorByValue","ruleName":"","applyTo":"cells","column":"InitiatedByUPN","themeName":null,"maxValue":null,"minValue":null,"reverseTheme":false,"visualType":"table"},{"id":"b7fa1b12-9a4a-42b1-9b08-8eb887afdbfa","ruleType":"colorByValue","ruleName":"","applyTo":"cells","column":"country","themeName":null,"maxValue":null,"minValue":null,"reverseTheme":false,"visualType":"table"},{"id":"3dbd2702-cde1-43d1-aed0-a689d9aee293","ruleType":"colorByValue","ruleName":"","applyTo":"cells","column":"Result","themeName":null,"maxValue":null,"minValue":null,"reverseTheme":false,"visualType":"table"},{"id":"954a3433-0930-479c-8fb8-745e9c8b1fb5","ruleType":"colorByValue","ruleName":"","applyTo":"cells","column":"activityCount","themeName":"traffic-lights","maxValue":null,"minValue":null,"reverseTheme":true,"visualType":"table"}],"selectedDataOnLoad":{"all":true,"limit":10}}}],"baseQueries":[],"parameters":[{"kind":"duration","id":"3aa9fba2-4e96-4c45-a218-daa383a1b370","displayName":"Time range","description":"","beginVariableName":"_startTime","endVariableName":"_endTime","defaultValue":{"kind":"dynamic","count":1,"unit":"hours"},"showOnPages":{"kind":"all"}}],"dataSources":[{"kind":"manual-kusto","id":"4b830f42-965f-4ac7-846f-f3ac0728065b","name":"Application","clusterUri":"https://YOURADX.YOUREGION.kusto.windows.net/","database":"Application","scopeId":"kusto"}],"pages":[{"name":"Page 1","id":"89a598dd-3b9b-467c-8e73-c986423fc4b3"}],"queries":[{"dataSource":{"kind":"inline","dataSourceId":"4b830f42-965f-4ac7-846f-f3ac0728065b"},"text":"//Use Proxy logs to hunt for Intune authentications\ndatabase('Network').table('proxy') \n| where TimeGenerated between (_startTime.._endTime)  \n| where referer has 'intune.microsoft.com' and hostname has 'login.microsoftonline.com'\n| summarize c=count() by user,tostring(record.department), bin(TimeGenerated, 12h)\n| sort by c desc | take 15\n//| where url has 'TenantAdminMenu' or url has 'Microsoft_Intune_DeviceSettings'\n//'https://intune.microsoft.com/#view/Microsoft_Intune_DeviceSettings/TenantAdminMenu/~/tenantStatus'\n\n","id":"ae9e4925-2659-486f-a8b0-4b0933a9ed95","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"4b830f42-965f-4ac7-846f-f3ac0728065b"},"text":"database('Identity').table('EntraIDSignin') \n| where TimeGenerated between (_startTime.._endTime)  \n| where AppDisplayName == \"Microsoft Intune Company Portal\" \n| where ConditionalAccessStatus == 'success'\n| where Location == 'US'  //Country specific search\n| where isnotempty(AlternateSignInName) and isnotempty(LocationDetails)\n| summarize c=count(),os=make_set(DeviceDetail.operatingSystem),browser=make_set(DeviceDetail.browser),  make_set(AppDisplayName),make_set(AuthenticationRequirement), country=make_set(LocationDetails.countryOrRegion),city=make_set(LocationDetails.city), make_set(OperationName), make_set(IsInteractive) by AlternateSignInName, bin(TimeGenerated, 12h)\n| sort by c desc\n| take 20","id":"6f287981-034c-45cd-8afc-90796d2a63c6","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"4b830f42-965f-4ac7-846f-f3ac0728065b"},"text":"//Query users mass accessing Intune related documentation\ndatabase('Application').table('O365Audit') \n| where TimeGenerated between (_startTime.._endTime)  \n| where SourceFileName has 'intune'\n| where OfficeWorkload != 'Exchange'\n| where UserId != \"app@sharepoint\"\n| summarize c=count(), make_set(Operation), make_set(SourceFileName), make_set(SourceRelativeUrl) by tostring(UserId), bin(TimeGenerated, 8h)\n| where c > 5 //Retrieve when 1 user accesses more than 10 Intune docs within 8 hours Edit as needeed\n| sort by c desc \n| take 20","id":"47037c20-c027-4703-b05d-e152bc213768","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"4b830f42-965f-4ac7-846f-f3ac0728065b"},"text":"//Query for new Device Registrations to Intune\ndatabase('Identity').table('EntraIDAudit')\n| where TimeGenerated between (_startTime.._endTime)  \n| where Category == 'Device' and ActivityDisplayName == 'Add device' //Intune Device Registration //For BYOD actions use \"Register device\" which shows personal device with a work account\n//| where Identity == 'Device Registration Service'\n| extend InitiatedByUser = tostring(parse_json(InitiatedBy).user.userPrincipalName), InitiatedByUPN = tostring(parse_json(InitiatedBy).user.userPrincipalName),\ndevice= tostring(parse_json(TargetResources).[0].displayName),  IPAddress = tostring(parse_json(InitiatedBy).user.ipAddress), \nCloudDeviceOSType  = tostring(parse_json(TargetResources)[0].modifiedProperties.[2].newValue)// Extraction says within TargetResources, go to position 0, then from modified properties count 2 within the array and retrieve the 'newValue'. Name this 'CloudDeviceOSType\n| where device !startswith \"CX\"  and device !startswith \"MX\" and device !startswith \"2M\" and device !startswith \"1H\" and device !startswith \"BK\"\nand device !startswith \"vdi\" and device !startswith \"US\" and device !startswith \"5cg\" and device !startswith \"vm\"\n//Uncomment to get line by line | project-reorder TimeGenerated, ActivityDisplayName, CloudDeviceOSType, device, Identity\n| summarize c=count(),  make_set(device), make_set(TimeGenerated,5) by ActivityDisplayName, CloudDeviceOSType\n| sort by c asc \n| take 20\n","id":"e69045fc-e187-41f3-b748-208cac48dd1e","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"4b830f42-965f-4ac7-846f-f3ac0728065b"},"text":"//Priv or Service account seen in Entra ID Risk detections\ndatabase('Identity').table('EntraIDUserRiskEvents') \n| where TimeGenerated between (_startTime.._endTime)  \n| where RiskDetail == \"none\" //none here translates to an admin hasn't dismissed this yet and/or AI/ML dismissed values\n| where UserDisplayName has_any (\"Generic\", \"Privileged\")\n    or UserPrincipalName endswith \"myadmin@scheme.yo\"//targeting generic or privileged accounts\n| extend AdditionalInfoParsed = parse_json(AdditionalInfo)\n| mv-expand RiskEntry = AdditionalInfoParsed\n| where RiskEntry.Key == \"riskReasons\"\n| extend RiskReasons = RiskEntry.Value\n| mv-expand RiskReason = RiskReasons\n| project\n    TimeGenerated,\n    DetectedDateTime,\n    OperationName,\n    RiskEventType,\n    RiskDetail,\n    UserPrincipalName,\n    UserDisplayName,\n    CorrelationId,\n    TokenIssuerType,\n    RiskReason,\n    IpAddress | take 20\n\n","id":"12446585-fe1c-48ee-8a94-9003131d60d5","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"4b830f42-965f-4ac7-846f-f3ac0728065b"},"text":"//Query for device deletion and wipes //Enrich with IP data to determie geolocation/ASN\ndatabase('Identity').table('EntraIDAudit')\n| where TimeGenerated between (_startTime.._endTime)  \n| extend InitiatedByUser = tostring(parse_json(InitiatedBy).user.userPrincipalName), InitiatedByUPN = tostring(parse_json(InitiatedBy).user.userPrincipalName),device= tostring(parse_json(TargetResources).[0].displayName),  IPAddress = tostring(parse_json(InitiatedBy).user.ipAddress)\n| where ActivityDisplayName has \"wipe ManagedDevice\" or ActivityDisplayName has \"Delete device\"\n| where InitiatedBy has \"user\" and InitiatedBy !has \"Sync_\" //Ignore normal syncing\n| extend GeoIPInfo = geo_info_from_ip_address(IPAddress)\n| extend country = tostring(parse_json(GeoIPInfo).country), state = tostring(parse_json(GeoIPInfo).state)\n| summarize count=count() by ActivityDisplayName, tostring(InitiatedByUser), IPAddress,country,state, device, bin(TimeGenerated, 1h) \n| take 20\n","id":"5897edac-be87-4b17-bf3e-ccc4f77d5d5c","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"4b830f42-965f-4ac7-846f-f3ac0728065b"},"text":"database('Identity').table('EntraIDAudit')\n| where TimeGenerated between (_startTime.._endTime)  \n| extend Hour = hourofday(TimeGenerated), DayOfWeek = dayofweek(TimeGenerated)\n| where DayOfWeek == 0 or DayOfWeek == 6 // Saturday or Sunday\n or Hour < 7 or Hour >= 19 // Outside 7am-7pm\n| where AADOperationType == \"Create\" // != 'Read' //r\n| extend InitiatedByUPN = tostring(parse_json(InitiatedBy).user.userPrincipalName), Target= tostring(parse_json(TargetResources).[0].displayName) //, IPAddress = tostring(parse_json(InitiatedBy).user.ipAddress)\n| where Target == 'Intune Administrator'\n| where ActivityDisplayName == 'Add member to role requested (PIM activation)'\n| project-reorder  TimeGenerated, InitiatedByUPN,ResultReason, Target,AADOperationType\n| take 100\n","id":"803a4881-ae86-49d3-8fbd-40f844bcb9aa","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"4b830f42-965f-4ac7-846f-f3ac0728065b"},"text":"//after hour changes is VERY common, does your org have approved change windows?\ndatabase('Identity').table('EntraIDAudit')\n| where TimeGenerated between (_startTime.._endTime)  \n| extend Hour = hourofday(TimeGenerated), DayOfWeek = dayofweek(TimeGenerated)\n| where DayOfWeek == 0 or DayOfWeek == 6 // Saturday or Sunday\n or Hour < 7 or Hour >= 19 // Outside 7am-7pm\n| where AADOperationType == \"Update\" or AADOperationType == \"Create\"\n| extend InitiatedByUPN = tostring(parse_json(InitiatedBy).user.userPrincipalName) ,ip = tostring(parse_json(InitiatedBy).user.ipAddress)\n| where InitiatedByUPN endswith \"myadmin.yo\" //your admin naming here\n| where  LoggedByService != 'PIM' and LoggedByService != \"Self-service Group Management\" //https://learn.microsoft.com/en-us/entra/identity/monitoring-health/reference-audit-activities\n| extend GeoIPInfo = geo_info_from_ip_address(ip)\n| extend country = tostring(parse_json(GeoIPInfo).country), state = tostring(parse_json(GeoIPInfo).state)\n| project-reorder InitiatedByUPN, ActivityDisplayName, LoggedByService, Result, ip, country,state\n| take 100\n","id":"b5019d4d-2eb4-4362-9547-ad2a8c804920","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"4b830f42-965f-4ac7-846f-f3ac0728065b"},"text":"database('Identity').table('EntraIDSignin') \n| where TimeGenerated between (_startTime.._endTime)  \n| where AppDisplayName == \"Microsoft Intune Company Portal\" \n| where ConditionalAccessStatus == 'success'\n| where Location != 'US' //add your company's location\n| where isnotempty(AlternateSignInName) and isnotempty(LocationDetails)\n| summarize c=count(),os=make_set(DeviceDetail.operatingSystem),browser=make_set(DeviceDetail.browser),  make_set(AppDisplayName),make_set(AuthenticationRequirement), country=make_set(LocationDetails.countryOrRegion),city=make_set(LocationDetails.city), make_set(OperationName), make_set(IsInteractive) by AlternateSignInName, bin(TimeGenerated, 8h)//\n| sort by c desc\n| take 20","id":"e27905a6-6776-4a30-ae73-0d43e5dddf93","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"4b830f42-965f-4ac7-846f-f3ac0728065b"},"text":"database('Identity').table('EntraIDAudit')\n| where TimeGenerated between (_startTime.._endTime)  \n| where AADOperationType == \"Update\" or AADOperationType == \"Create\"\n| extend InitiatedByUPN = tostring(parse_json(InitiatedBy).user.userPrincipalName) ,ip = tostring(parse_json(InitiatedBy).user.ipAddress)\n| where InitiatedByUPN endswith \"myadmin@lol.yo\" or InitiatedByUPN endswith \"youradmin@lol.yo\"  //your admin naming here\n| where  LoggedByService != 'PIM' and LoggedByService != \"Self-service Group Management\" //https://learn.microsoft.com/en-us/entra/identity/monitoring-health/reference-audit-activities\n| extend GeoIPInfo = geo_info_from_ip_address(ip)\n| extend country = tostring(parse_json(GeoIPInfo).country), state = tostring(parse_json(GeoIPInfo).state)\n| project-reorder InitiatedByUPN, ActivityDisplayName, LoggedByService, Result, ip, country,state\n| summarize activityCount=count(ActivityDisplayName),make_set(ActivityDisplayName), make_set(country),make_set(state),make_set(TimeGenerated,10), make_set(ip) by InitiatedByUPN, Result\n| sort by activityCount desc \n| take 20","id":"7eb6be4e-92e4-49cc-b1cb-3a9c491f6d7f","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"4b830f42-965f-4ac7-846f-f3ac0728065b"},"text":"database('Identity').table('EntraIDAudit')\n| where TimeGenerated between (_startTime.._endTime)  \n| where AADOperationType == \"Update\" or AADOperationType == \"Create\"\n| extend InitiatedByUPN = tostring(parse_json(InitiatedBy).user.userPrincipalName) ,ip = tostring(parse_json(InitiatedBy).user.ipAddress)\n| where InitiatedByUPN !endswith \"myadmin@lol.yo\"  and InitiatedByUPN !endswith \"youradmin@lol.yo\"  //your admin naming here\n| where InitiatedByUPN !startswith \"Sync_\"\n| where isnotempty(InitiatedByUPN)\n| where  LoggedByService != 'PIM' and LoggedByService != \"Self-service Group Management\" //https://learn.microsoft.com/en-us/entra/identity/monitoring-health/reference-audit-activities\n| extend GeoIPInfo = geo_info_from_ip_address(ip)\n| extend country = tostring(parse_json(GeoIPInfo).country), state = tostring(parse_json(GeoIPInfo).state)\n| project-reorder InitiatedByUPN, ActivityDisplayName, LoggedByService, Result, ip, country,state\n| summarize activityCount=count(ActivityDisplayName),make_set(ActivityDisplayName), make_set(country),make_set(state),make_set(TimeGenerated,10), make_set(ip) by InitiatedByUPN, Result\n| sort by activityCount desc \n| take 20","id":"40b826ae-9a8c-48f8-b82c-310552935921","usedVariables":["_endTime","_startTime"]}]}