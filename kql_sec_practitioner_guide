//Search every table in a database for an IoC
let term_t = '';
let findSourceIPLogs = (arg0: string, arg1: string) {
    union withsource=_TableName *  
  | where TimeGenerated >= ago(30d)
};
findSourceIPLogs("Application", ("term_t"))
| where record contains (term_t) or P contains (term_t) // some Application table logs do not contain a 'record' column //Swap database for your database name
| take 500 //For purposes of query efficiency, ONLY 500 RANDOM LOGS ARE RETRIEVED. This means: The absence of logs does NOT necessarily imply the term is absent in our logs. The presence of the term in some tables but not others does NOT mean the term is not also present in other tables.
