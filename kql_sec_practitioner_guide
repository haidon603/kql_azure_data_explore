//-------------------------------------Timezones/Dashboards/Paramenters-----------------------------------------
//KQL Dashboards do not have a submit button, which means when a dashboard is opened, it will immediately run.
//These are mitigations to hardcode the dashboard to short/no time values
//Defines parameterized variables for time range handling and timezone offset calculation, intended to be used as a reusable header
//Sets up input parameters (account, time range, timezone)
 
//Dynamically decides which time window to use and converts a timezone string into a numeric offset
//Daylight time hour offset
UTC 0 hours
PDT 7 hours
MDT 6 hours
CDT 5 hours
EDT 4 hours
Anything else 0 hours
 
//iif(condition, value_if_true, value_if_false)
//If _accounts equals the literal string "PLACEHOLDER":
//_st is set to the current time  now(0s) Returns the current timestamp
//Else:
//_st is set to _startTime
let _st = iif(_account=="PLACEHOLDER",now(0s),_startTime);
let _et = iif(_account=="PLACEHOLDER",now(0s),_endTime);
 
let _endTime = datetime(2026-04-02T14:31:32Z);
let _startTime = datetime(2026-04-02T13:31:32Z);
let _tzone = 'CDT'; //Default Central
let _tz =
    iif(_tzone=="UTC",0h,
    iif(_tzone=="PDT",7h,
    iif(_tzone=="MDT",6h,
    iif(_tzone=="CDT",5h,
    iif(_tzone=="EDT",4h,
    0h)))));
Table
| where TimeGenerated between (_startTime .. _endTime )
| extend CST = TimeGenerated - 5h
| extend EST = TimeGenerated - 4h
| extend PST = TimeGenerated - 7h
| extend TimeGenerated = TimeGenerated -_tz
 
let _account = 'PLACEHOLDER'; //Assigning the literal string PLACEHOLDER to _account variable
let _startTime = datetime(2026-01-02T01:00:00Z);  //tokenized parameter in dashboard
let _endTime = datetime(2026-01-01T01:00:01Z); //tokenized parameter in dashboard //Hardcode _endTime to be 1 second later
let _tzone = 'UTC'; //default to UTC
let _st = iif(_account=="PLACEHOLDER",now(),_startTime); //If _account equals "PLACEHOLDER" then assign _st to now() assign _st = _startTime //This prevents dashboard from running until a parameter is given (look)
let _et = iif(_account=="PLACEHOLDER",now(),_endTime);
let _tz =
    iif(_tzone=="UTC",0h,
    iif(_tzone=="PDT",7h,
    iif(_tzone=="MDT",6h,
    iif(_tzone=="CDT",5h,
    iif(_tzone=="EDT",4h,
    0h)))));
Table
| where TimeGenerated between (_st.._et)
| extend TimeGenerated = TimeGenerated -_tz
 
