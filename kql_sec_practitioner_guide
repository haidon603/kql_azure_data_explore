//-------------------------------------Query Design Template-----------------------------------------
// Always filter by TimeGenerated FIRST to reduce extents scanned. When possible, use 'take' to limit returned logs.
Table | where TimeGenerated > ago(1d) | where FieldName == "your search here"
 
//-------------------------------------String Searching-----------------------------------------
//Performance Cost Ranking
// fastest (uses indexes)
// ==, !=, has, has_any, startswith, endswith
//
// medium
// contains, regex extract
//
// slower/avoid
// search *, where * has, regex
 
//MS has docs on useful operators like make_set,startswith,isnotempty,hash_sha256,base64_decode_tostring, endswith,strlen, !contains, ipv4_is_private
//https://learn.microsoft.com/en-us/kusto/query/
 
// case sensitive
Table | where name == "Foo"
// case sensitive
Table | where name != "Foo"
// not case sensitive
Table | where name =~ "foo"
// not case sensitive
Table | where name !~ "foo"
 
//Case In-Sensitive
// OPERATOR       |            DESCRIPTION                            |       EXAMPLE (YIELDS TRUE)
// =~             |   Case-insensitive exact match                    |   "Trojan.exe" =~ “trojan.EXE”
// contains       |    Substring match, case-insensitive              |     "DownloadTrojan.exe" contains “trojan”
// has            |     Term match, case-insensitive                  |    "Error: Access Denied" has “denied”
// startswith     |  Starts with substring, case-insensitive          |     "malicious_payload.exe" startswith "Malicious"
// endswith       | Ends with a specified substring, case-insensitive |   "malware.exe" endswith “Exe”
 
//Case sensitive (Case-sensitive operations are typically preferred, as they require less processing)
// OPERATOR      |         DESCRIPTION                         |  EXAMPLE (YIELDS TRUE)
// ==            |         Exact match                         |  "admin" == "admin"
// contains_cs   |    Substring match, case-sensitive          |  "MalwareFile.exe" contains_cs “File”
// has_cs        |    Term match, case-sensitive               |      "Failed: Login Attempt" has_cs “Failed”
// startswith_cs |       Starts with substring, case-sensitive |         "Malware.exe" startswith_cs “Mal”
// endswith_cs   |    Case-sensitive end with substring        |  "DataReport.PDF" endswith_cs "PDF"
 
// 'Contains' or 'search' is like *search* are VERY computationally expensive
//Prefer to use a single search operator over several consecutive search operators
//yay
search "file" and ("written" or "deleted")
//nay
search "file" | search "written" or "deleted"
//avooid
search * | where * has "file" and * has "written"
 
//-------------------------------------Time Searching-----------------------------------------
 
//ago() Subtracts the given timespan from the current UTC time
Table | where TimeGenerated > ago(7d)  // now subtract 7 days
// ingestion_time returns the approximate datetime in UTC format, indicating when the record was ingested and stored in Azure
Table | where ingestion_time() > ago(7d)  
 
//Search for a specific date in UTC format.  datetime(year.month.day)
Table | where TimeGenerated >= datetime(2026-01-01)
//A date and time in UTC format.    datetime(year.month.day hour:minute:second.milliseconds)
Table | where TimeGenerated >= datetime(2026-01-01 23:59:59.9)  
 
//Search a range. 'between' can operate on any numeric, datetime, or timespan expression. | where field between (leftRange..rightRange) i.e. column >= A and column <= B
Table | where TimeGenerated between (datetime(2026-01-01) .. datetime(2026-02-01))
 
//Group events into time bins
Table | summarizeEventCount = count() bybin(StartTime, 7d)
 
// Group events by day
Table | summarize Count = countif(name=="Alice" and status=="Failure") by bin(TimeGenerated, 1d)
 
//Set threshold for more than 30 events in a 1-minute bucket
Table | summarize NumRecords=count() by bin (TimeGenerated, 1m) | where NumRecords >= 30
 
//-------------------------------------Networking-----------------------------------------
Network | where not(ipv4_is_private(LocalAddressIP4))
 
Network | where ingestion_time() > ago(3d)
    and ipv4_is_in_range(RemoteAddressIP4, "10.0.0.0/8") == false
    and ipv4_is_in_range(RemoteAddressIP4, "192.168.0.0/16") == false
    and ipv4_is_in_range(RemoteAddressIP4, "172.16.0.0/12") == false
 
Network | where ipv4_is_in_range(src, "10.0.0.0/8") //Search for internal device trying to go out to this IP range
 
//Geo info from IP
Network | extend     geo_info_from_ip_address(RemoteAddressIP4)
| extend country = tostring(IPGeo.country)
| extend city = tostring(IPGeo.city)
 
