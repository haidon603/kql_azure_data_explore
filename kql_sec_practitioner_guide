//-------------------------------------Field Manipulation/Extraction-----------------------------------------
//Function                      |Description
//parse_json() or todynamic()   |Interprets a string as a JSON value and returns the value as dynamic. Use either of these to refer to a field: JsonField.Key or JsonField["Key"]
//bag_unpack                    |The bag_unpack plugin unpacks a single column of type dynamic, by treating each property bag top-level slot as a column.
//mv_expand()                   |Applied on a dynamic-typed array or property bag column so that each value in the collection gets a separate row. All the other columns in an expanded row are duplicated. mv_expand is the easiest way to process JSON arrays.
//mv_apply()                    |Applies a subquery to each record and returns the union of the results of all subqueries. Apply a query to each value in an array.
 
//extract json nested fields
Table | extend TargetUserName = tostring(parse_json(record).TargetUserName)
 
//concatenate values from the domain column, with a double forward slash, and values from the username column.
Table | extend Account = strcat(domain, "//", username)
 
//regex
Table | extend extract_all(@"user (\w+).*user (\w+)", "user tom and user jerry are at it again") // [["tom","jerry"]]
| project  FileExtension =  (extract("\\.[0-9a-z]+$",0,TargetFileName)), TargetFileName, event_simpleName
 
//dynamic data types
//We are using the second group (counting 0,1,2) within the JSON and then calling "labeledName", so the query says use column msgParts, count 2 within the array, and retrieve "labeledName".
Table | extend tostring(msgParts[2].labeledName),attachment_extension = tostring(msgParts[2].labeledExt)
 
// using iif you can perform multiple calculations to determine a string value or additional calculations
Table | extend Priority = iif(status=="Failure" and department=="Server Administrator", "High Priority", "Normal Priority")
 
//Replace Strings
Table | extend replace_string("Hello world!", "Hello", "Goodbye")
 
//Combine Fields
Table | extend name_dept = strcat(name," - ",department)
 
//Retrieve first not null field
Table | extend Priority = coalesce(Priority,Urgency)
 
// All user boxes use the format first.last@domain.com. Most shared boxes have a longer name without a period.
// We're going to use the presence of a '.' in the mailboxownerUPN as a proxy for being a user box. This won't eliminate ALL shared boxes, but the majority of them
Table | extend NumPeriods = array_length(split(MailboxOwnerUPN, '.'))
 
//Extract request # from message
Table | where SyslogMessage  has_cs 'request'
// go to 8 position and take 2 chars then put into new column titled 'req#'
| extend req# = substring(SyslogMessage, 8,2)
| project req#, req, SyslogMessage
 
//Remove the "Request XX:" prefix from the Syslog message.
//Use trim() or  trim_start() with the following regular expression: request \d+:
Table | extend trim(@"request \d+:", SyslogMessage)
 
//Extract username and filename
Table | extend userfile=extract_all(@"User\s(\w+).*\s(\w+\.\S+)\sfrom", SyslogMessage)[0]
| extend User=userfile[0], File=userfile[1]
 
//Extrac Blurbs of Text
Table | where event_simpleName contains "Script"
| extend blurb = extract("(.{1,30}(bitfinex|ethereum).{1,30})",1,ScriptContent)
| where not(blurb == "")
| project TimeGenerated,TargetFileName,event_simpleName,blurb,record
 
