"seriesColors":{},"hideLegend":false,"legendLocation":"bottom","xColumnTitle":"","xAxisScale":"linear","verticalLine":"","crossFilterDisabled":false,"drillthroughDisabled":false,"forceAxisTicks":false,"crossFilter":[],"drillthrough":[],"selectedDataOnLoad":{"all":true,"limit":10}}},{"id":"71a0d944-969b-47bb-9d22-61ee86b19152","title":"Rare User Names","visualType":"bar","pageId":"85d5555e-f8b5-4e14-8b1c-7a58811bc3c7","layout":{"x":9,"y":9,"width":9,"height":7},"queryRef":{"kind":"query","queryId":"eb5c17cb-5a30-4830-b316-9b52d0107313"},"visualOptions":{"xColumn":null,"multipleYAxes":{"additional":[],"showMultiplePanels":false,"base":{"horizontalLines":[],"yAxisScale":"linear","yAxisMaximumValue":null,"yAxisMinimumValue":null,"columns":[],"label":"","id":"-1"}},"yColumns":null,"seriesColumns":null,"anomalyColumns":null,"map__longitudeColumn":null,"map__latitudeColumn":null,"seriesColors":{},"hideLegend":false,"legendLocation":"bottom","xColumnTitle":"","xAxisScale":"linear","verticalLine":"","crossFilterDisabled":false,"drillthroughDisabled":false,"forceAxisTicks":false,"crossFilter":[],"drillthrough":[],"selectedDataOnLoad":{"all":true,"limit":10}}}],"baseQueries":[],"parameters":[{"kind":"duration","id":"d2564abf-8395-41f2-9cff-289d14a8b0c3","displayName":"Time range","description":"","beginVariableName":"_startTime","endVariableName":"_endTime","defaultValue":{"kind":"dynamic","count":1,"unit":"hours"},"showOnPages":{"kind":"all"}}],"dataSources":[{"kind":"manual-kusto","id":"a7303e6c-05bb-49af-8eee-3c2355e7c922","name":"Endpoint","clusterUri":"https://YOURADXNAME.YOURREGION.kusto.windows.net/","database":"Endpoint","scopeId":"kusto"}],"pages":[{"name":"Page 1","id":"85d5555e-f8b5-4e14-8b1c-7a58811bc3c7"}],"queries":[{"dataSource":{"kind":"inline","dataSourceId":"a7303e6c-05bb-49af-8eee-3c2355e7c922"},"text":"//New user agents seen in the last 2 weeks with a low prevalence in the last 6 months\nlet baseline=\n    database('Network').table('WebAppAuth') \n    | where TimeGenerated between (ago(180d) .. ago(14d)) //Search last 6 months but ignore the last 14 days\n    | project known_UA = user_agent, user_agent //For efficiency and readability project only user_agent >  make a new column titled known_UA from existing column user_agent but allow existing column user_agent to persist for join statement later\n    | summarize baseline = count() by known_UA, user_agent;\nlet new =\n    database('Network').table('WebAppAuth') \n    | where TimeGenerated > ago(14d) //Search the last 14 days\n    | project new_UA = user_agent, user_agent //For efficiency and readability project only user_agent > make a new column titled new_UA from existing column user_agent but allow existing columnm user_agent to persist for join statement later\n    | summarize new = count() by new_UA, user_agent;\nbaseline //Use the table titled baseline as left table\n| join kind=rightouter new on user_agent //Right outer join means find all matching records for column useragent from table 'baseline' in table 'new' and also return all user agents from the 'new' table e.g. user agents seen in last 14 days but not seen in last 180 days\n| project-away user_agent, user_agent1 //Remove these kusto columns from results as we only needed them to join the 2 different tables\n| where isnotempty(new_UA) //Ignore extraneous logs where column new_UA has has an empty value\n| where isempty(known_UA ) or (baseline < 50  and new > 10) //Look for useragent not seen before OR useragent with a low prevalence // modify as needed\n| sort by new desc\n\n","id":"4dfd69d3-cb0e-4b7a-8a4c-d1b4ebcafb0e","usedVariables":[]},{"dataSource":{"kind":"inline","dataSourceId":"a7303e6c-05bb-49af-8eee-3c2355e7c922"},"text":"//user agent switching by username\ndatabase('Network').table('WebAppAuth') \n| where TimeGenerated between (_startTime .. _endTime)\n| where isnotempty(logon_last_username) //Ignore extraneous logs where column logon_last_username has has an empty value\n| summarize ua_count = dcount(user_agent), user_agent = make_set(user_agent, 5) by logon_last_username\n| sort by ua_count desc ","id":"f1315a88-7729-4d4a-914f-c9ffab16040c","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"a7303e6c-05bb-49af-8eee-3c2355e7c922"},"text":"//same user agent for many accounts\ndatabase('Network').table('WebAppAuth') \n| where TimeGenerated between (_startTime .. _endTime)\n| where isnotempty(logon_last_username) //Ignore extraneous logs where column logon_last_username has has an empty value\n| summarize\n    ua_count = dcount(logon_last_username),\n    logon_last_username = make_set(logon_last_username, 5)\n    by user_agent\n| sort by ua_count desc ","id":"7012eee6-1729-4781-992b-902dd508a04d","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"a7303e6c-05bb-49af-8eee-3c2355e7c922"},"text":"//high velocity per user agent\ndatabase('Network').table('WebAppAuth') \n| where TimeGenerated between (_startTime .. _endTime)\n| where isnotempty(user_agent)\n| summarize req_count=count() by user_agent, bin(TimeGenerated, 10m)\n| sort by req_count desc ","id":"42865f95-cc6a-4dca-bb68-0d8d3915406f","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"a7303e6c-05bb-49af-8eee-3c2355e7c922"},"text":"//user agent length anomalies\ndatabase('Network').table('WebAppAuth') \n| where TimeGenerated between (_startTime .. _endTime)\n| extend ua_length = strlen(user_agent)\n| where isnotempty(user_agent) //Ignore extraneous logs where column user_agent has has an empty value\n| summarize number_seen = count() by user_agent, ua_length\n| sort by number_seen asc \n\n","id":"080c5512-e198-4cb6-acd9-1517669f1026","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"a7303e6c-05bb-49af-8eee-3c2355e7c922"},"text":"//high velocity per user agent\ndatabase('Network').table('WebAppAuth') \n| where TimeGenerated between (_startTime .. _endTime)\n| where isnotempty(user_agent) //Ignore extraneous logs where column user_agent has has an empty value\n| summarize ua_count=count() by user_agent\n| sort by ua_count desc | take 7\n| render piechart \n\n","id":"1a994eae-c81d-41fa-9963-dd47a2ac1149","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"a7303e6c-05bb-49af-8eee-3c2355e7c922"},"text":"//high velocity per user agent\ndatabase('Network').table('WebAppAuth') \n| where TimeGenerated between (_startTime .. _endTime)\n| where isnotempty(logon_last_username) //Ignore extraneous logs where column user_agent has has an empty value\n| summarize name_count=count() by logon_last_username\n| sort by name_count desc | take 10\n| render barchart   \n\n","id":"3558fdc5-94a6-439c-b921-97efa35b0706","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"a7303e6c-05bb-49af-8eee-3c2355e7c922"},"text":"//high velocity per user agent\ndatabase('Network').table('WebAppAuth') \n| where TimeGenerated between (_startTime .. _endTime)\n| where isnotempty(logon_last_username) //Ignore extraneous logs where column user_agent has has an empty value\n| summarize name_count=count() by logon_last_username\n| sort by name_count asc | take 10\n| render barchart   \n\n","id":"eb5c17cb-5a30-4830-b316-9b52d0107313","usedVariables":["_endTime","_startTime"]}]}