//Curl and Wget are interesting in cybersecurity because they are versatile tools that are easily abused for malicious purposes, yet they are also essential for security professionals. 
//Their presence as legitimate, built-in system tools means that threat actors can use them for everything from malware delivery to data exfiltration, often without being detected by basic security scans.  
database('MyEndpoint').MyEDR
| where ingestion_time() > ago(60d) 
    and (ImageFileName contains "curl" or ImageFileName contains "wget")
| extend  Extracted_url = extract("(https?:\\/\\/[^\\/]+\\/([a-zA-Z0-9\\.\\-]+\\/?)*)", 1, CommandLine)
| where not(Extracted_url == "")
    and not(Extracted_url matches regex "^https?://[a-z\\-0-9\\.]+.(my|foo)bar.com.*")
    and not(Extracted_url matches regex "^https?://(global\\.endpoint\\.security\\.microsoft\\.com |www\\.w3\\.org|api\\.github\\.com|api\\.zoom\\.us|clients2\\.google\\.com|127\\.0\\.0\\.1|localhost")
| extend Extracted_IP = extract("(([0-9]{1,3})\\.([0-9]{1,3})\\.([0-9]{1,3})\\.(([0-9]{1,3})))",1,Extracted_url) //extract ip from newly generated Extracted_url column
| project RemoteIP = coalesce(RemoteAddressIP4, Extracted_IP), //coalesce CS IP field with extracted IP from cli web request
Extracted_url, event_simpleName,ImageFileName,CommandLine,UserName,SensorGroupingTags,OU,TimeGenerated
| extend geo_info_from_ip_address(RemoteIP) //enrich IP
| project RemoteIP, geo_info = strcat(Column1.state, " ", Column1.country), //concatenate newly created geo ip enrichment
Extracted_url, event_simpleName,ImageFileName,CommandLine,UserName,SensorGroupingTags,OU,TimeGenerated
| summarize count(Extracted_url),make_set(RemoteIP), make_set(geo_info),  make_set(event_simpleName), make_set(ImageFileName), make_set(CommandLine,15), make_set(UserName),make_set(SensorGroupingTags,10), make_set(OU,10), make_set(TimeGenerated,10) by Extracted_url
| sort by tostring(set_geo_info) asc
